/*
 * Copyright (c) 2024 Pluto Keyboard
 * SPDX-License-Identifier: MIT
 *
 * Pluto - 5x6 column-staggered split keyboard
 * MCU: nice!nano v2 (nRF52840)
 *
 * Matrix: 5 rows x 6 cols per half = 30 keys per half = 60 total
 *
 * Rows (both halves, top to bottom):
 *   row 0 = num    → P0.31
 *   row 1 = top    → P0.29
 *   row 2 = home   → P0.02
 *   row 3 = bottom → P1.15
 *   row 4 = mod    → P1.13
 *
 * Columns LEFT (left to right = innermost first):
 *   col 0 = first  → P0.20
 *   col 1 = second → P0.22
 *   col 2 = third  → P0.24
 *   col 3 = fourth → P1.00
 *   col 4 = fifth  → P0.11
 *   col 5 = sixth  → P0.17
 *
 * Columns RIGHT (left to right = innermost first, physical mirror):
 *   col 0 = sixth  → P0.17
 *   col 1 = fifth  → P0.11
 *   col 2 = fourth → P1.00
 *   col 3 = third  → P0.24
 *   col 4 = second → P0.22
 *   col 5 = first  → P0.20
 *
 * Diode direction: col2row
 */

#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix_transform = &default_transform;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <12>;
        rows = <5>;
        map = <
            RC(0,0)  RC(0,1)  RC(0,2)  RC(0,3)  RC(0,4)  RC(0,5)    RC(0,6)  RC(0,7)  RC(0,8)  RC(0,9)  RC(0,10) RC(0,11)
            RC(1,0)  RC(1,1)  RC(1,2)  RC(1,3)  RC(1,4)  RC(1,5)    RC(1,6)  RC(1,7)  RC(1,8)  RC(1,9)  RC(1,10) RC(1,11)
            RC(2,0)  RC(2,1)  RC(2,2)  RC(2,3)  RC(2,4)  RC(2,5)    RC(2,6)  RC(2,7)  RC(2,8)  RC(2,9)  RC(2,10) RC(2,11)
            RC(3,0)  RC(3,1)  RC(3,2)  RC(3,3)  RC(3,4)  RC(3,5)    RC(3,6)  RC(3,7)  RC(3,8)  RC(3,9)  RC(3,10) RC(3,11)
            RC(4,0)  RC(4,1)  RC(4,2)  RC(4,3)  RC(4,4)  RC(4,5)    RC(4,6)  RC(4,7)  RC(4,8)  RC(4,9)  RC(4,10) RC(4,11)
        >;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "col2row";

        /*
         * Row pins are identical on both halves.
         * NOTE: col-gpios are defined per-side in the left/right overlay files
         * because the physical column order is mirrored.
         */
        row-gpios
            = <&gpio0 31 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* row 0: num */
            , <&gpio0 29 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* row 1: top */
            , <&gpio0  2 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* row 2: home */
            , <&gpio1 15 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* row 3: bottom */
            , <&gpio1 13 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* row 4: mod */
            ;
    };
};
